{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the DnD database, either a DM or a player.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["dm", "player"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "Entity": {
      "title": "Entity",
      "description": "A generic entry in the DnD database (npc, settlement, landmark, etc.).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["npc", "settlement", "landmark", "country", "faction", "shop", "item", "note"] },
        "name": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content of the entity." },
        "tags": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of tags or IDs of other entities."
        },
        "ownerId": { "type": "string", "description": "UID of the DM who created this." },
        "isPublic": { "type": "boolean", "description": "If true, all players can read the main content." },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of image URLs or media references (media:ID)."
        },
        "mapConfig": {
          "type": "object",
          "properties": {
            "mediaId": { "type": "string", "description": "The ID of the media asset to use as a map." },
            "pins": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "number", "description": "X coordinate as percentage (0-100)" },
                  "y": { "type": "number", "description": "Y coordinate as percentage (0-100)" },
                  "targetEntityId": { "type": "string", "description": "The ID of the entity this pin links to." }
                },
                "required": ["x", "y", "targetEntityId"]
              }
            }
          }
        },
        "locationId": { "type": "string", "description": "The ID of the parent entity (for 'up' navigation)." },
        "playerKnowledge": {
          "type": "object",
          "description": "Map of player UID to a string describing what they know about this entity."
        },
        "locationId": { "type": "string", "description": "The ID of the parent entity (for 'up' navigation)." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "name", "content", "tags", "ownerId", "isPublic", "createdAt", "updatedAt"]
    },
    "Media": {
      "title": "Media",
      "description": "Stores heavy media assets like base64 images separately from entities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string", "description": "The ID of the entity this media belongs to." },
        "campaignId": { "type": "string", "description": "The ID of the campaign this media belongs to." },
        "data": { "type": "string", "description": "The base64 encoded image data." },
        "mimeType": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "campaignId", "data", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/entities/{entityId}": {
      "schema": { "$ref": "#/entities/Entity" },
      "description": "Stores all DnD world entities."
    },
    "/media/{mediaId}": {
      "schema": { "$ref": "#/entities/Media" },
      "description": "Stores base64 image data to avoid document size limits."
    },
    "/campaigns/{campaignId}": {
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "dmId": { "type": "string" },
          "players": { "type": "array", "items": { "type": "string" } },
          "joinCode": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "dmId", "players", "joinCode", "createdAt"]
      },
      "description": "Stores campaign metadata and membership."
    },
    "/relationships/{relId}": {
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "campaignId": { "type": "string" },
          "sourceId": { "type": "string" },
          "targetId": { "type": "string" },
          "targetName": { "type": "string" },
          "label": { "type": "string" },
          "reverseId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "campaignId", "sourceId", "targetId", "targetName", "label", "reverseId", "createdAt"]
      },
      "description": "Stores connections between entities."
    }
  }
}
