{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the DnD database, either a DM or a player.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["dm", "player"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "Entity": {
      "title": "Entity",
      "description": "A generic entry in the DnD database (npc, settlement, landmark, etc.).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["npc", "settlement", "landmark", "country", "faction", "shop", "item", "note"] },
        "name": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content of the entity." },
        "tags": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of tags or IDs of other entities."
        },
        "ownerId": { "type": "string", "description": "UID of the DM who created this." },
        "isPublic": { "type": "boolean", "description": "If true, all players can read the main content." },
        "playerKnowledge": {
          "type": "object",
          "description": "Map of player UID to a string describing what they know about this entity."
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "name", "content", "tags", "ownerId", "isPublic", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/entities/{entityId}": {
      "schema": { "$ref": "#/entities/Entity" },
      "description": "Stores all DnD world entities."
    }
  }
}
